{
    "name": "sympress/bundle",
    "description": "Attribute-driven WordPress framework bundle with Symfony DI and more",
    "type": "symfony-bundle",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "symfony/dependency-injection": "^8.0",
        "symfony/config": "^8.0",
        "symfony/finder": "^8.0",
        "symfony/http-kernel": "^8.0",
        "symfony/event-dispatcher": "^8.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0",
        "szepeviktor/phpstan-wordpress": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "SymPress\\Bundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SymPress\\Bundle\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
